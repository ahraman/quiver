<!DOCTYPE html>
<html>
  <head>
    {% block head -%}
    <title>{{ page.title }} &ndash; {{ website }}</title>

    <link rel="stylesheet" href="assets/stylesheets/main.css" />
    {%- endblock head %}
  </head>
  <body>
    {% block body -%}
      <main>
        <div id="content">
          {% block content %}{{ page.content }}{% endblock content %}
        </div>
      </main>
    {%- endblock body %}
  </body>
</html>
